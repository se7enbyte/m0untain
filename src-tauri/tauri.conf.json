{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "m0untain",
  "version": "0.1.0",
  "identifier": "com.m0untain.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "m0untain",
        "width": 1320,
        "height": 840,
        "minWidth": 980,
        "minHeight": 640,
        "theme": "Dark",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "m0untain",
    "category": "Utility",
    "shortDescription": "Host firewall with DDoS and scan shielding.",
    "longDescription": "m0untain is a Windows host firewall built on the Windows Filtering Platform, with built-in per-IP DDoS/flood rate limiting and port-scan detection, live signal metrics, and detachable panels.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": true,
        "languages": ["English", "Turkish"]
      }
    }
  }
}
